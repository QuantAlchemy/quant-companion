{
  "name": "quant-companion",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:convex": "convex dev",
    "build": "vite build",
    "build:convex": "convex deploy --cmd \"vite build\"",
    "build:local": "vite build",
    "env:generate:local": "op inject -i .env.local.tpl -o .env.local",
    "env:generate:production": "op inject -i .env.production.tpl -o .env.production",
    "generate-routes": "tsr generate",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
