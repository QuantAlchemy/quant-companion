    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "dayjs": "^1.11.21",
    "lucide-react": "^0.577.0",
    "nitro": "3.0.260610-beta",
    "papaparse": "^5.5.4",
    "plotly.js-dist-min": "^3.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plotly.js": "^4.0.0",
    "sonner": "^2.0.7",
